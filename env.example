# Copy this to .env and fill in values

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # From @BotFather

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # https://console.anthropic.com
# OPENAI_API_KEY=            # Alternative if you prefer GPT-4o-mini

# ── Database ─────────────────────────────────────────────────────────────────
SUPABASE_URL=                # https://xxxx.supabase.co
SUPABASE_KEY=                # anon key for reads; service_role key for writes

# ── Paper sources ─────────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=    # Optional but recommended — apply at semanticscholar.org/product/api
NCBI_API_KEY=                # Optional — https://www.ncbi.nlm.nih.gov/account/ (raises rate limit to 10/s)

# ── Digest settings ───────────────────────────────────────────────────────────
MIN_RELEVANCE_SCORE=6        # Papers below this score are dropped (0–10)
MAX_PAPERS_PER_DIGEST=10     # Max papers per user per day
DAYS_BACK=1                  # How many days back to fetch (increase to 2 on Mondays to catch weekend)

# ── arXiv categories (comma-separated) ───────────────────────────────────────
# Adjust to your field. Full list: https://arxiv.org/category_taxonomy
ARXIV_CATEGORIES=cs.CV,eess.IV,cs.LG,q-bio.QM

# ── Semantic Scholar / PubMed queries ────────────────────────────────────────
S2_QUERY=machine learning       # Free-text query for Semantic Scholar (requires API key above)
PUBMED_QUERY=                   # Optional — leave blank to skip PubMed entirely
